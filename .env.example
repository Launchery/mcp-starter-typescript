# Environment Variables
#
# Copy this file to .env and fill in the values your MCP server needs.
# Required variables must be set before the server starts.
# Optional variables have sensible defaults.

# Example: API key for an external service (optional in starter)
# API_KEY=your-api-key-here

# Example: Base URL for an external API (optional in starter)
# API_BASE_URL=https://api.example.com

# Node environment (optional, defaults to "development")
# NODE_ENV=development
