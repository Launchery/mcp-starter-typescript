{
  "name": "mcp-starter-typescript",
  "version": "1.0.0",
  "description": "Starter template for building MCP servers in TypeScript",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "echo \"No tests yet\" && exit 0",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": ["mcp", "typescript", "starter", "template", "ai-devtools"],
  "author": "Launchery",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0"
  }
}
